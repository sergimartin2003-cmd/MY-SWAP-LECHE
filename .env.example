# ─────────────────────────────────────────────────────────────────────────────
# NexSwap — Environment Variables
# Copy this file to .env.local and fill in the values.
# Never commit .env.local to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── REQUIRED ─────────────────────────────────────────────────────────────────

# Your wallet address — receives all platform fees (0.25% of every swap).
# ⚠️ If not set, fees are sent to the zero address and burned.
VITE_TREASURY_ADDRESS=0xYourWalletAddressHere

# ── OPTIONAL — WalletConnect (enables QR code wallet connections) ──────────
# Get a free project ID at https://cloud.walletconnect.com
VITE_WC_PROJECT_ID=your_walletconnect_project_id

# ── OPTIONAL — NexSwapRouter (on-chain fee collection) ────────────────────
# Deploy contracts/NexSwapRouter.sol (see contracts/DEPLOY.md), then paste
# the deployed contract address for each chain below.
# Without these, swaps go directly through Uniswap (fee is UI-only).

VITE_NEXSWAP_ROUTER_MAINNET=0x
VITE_NEXSWAP_ROUTER_BASE=0x
VITE_NEXSWAP_ROUTER_ARBITRUM=0x
VITE_NEXSWAP_ROUTER_OPTIMISM=0x
VITE_NEXSWAP_ROUTER_POLYGON=0x

# ── OPTIONAL — Analytics ──────────────────────────────────────────────────
# Add your analytics provider key here if needed
# VITE_ANALYTICS_ID=
